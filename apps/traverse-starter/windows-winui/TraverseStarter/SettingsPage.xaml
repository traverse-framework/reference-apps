<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TraverseStarter.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="480">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBox
                x:Name="BaseUrlBox"
                Header="Runtime URL"
                PlaceholderText="http://127.0.0.1:8787"
                TextChanged="Setting_TextChanged" />

            <TextBox
                x:Name="WorkspaceBox"
                Header="Workspace"
                PlaceholderText="local-default"
                TextChanged="Setting_TextChanged" />

            <TextBlock
                Text="Default: http://127.0.0.1:8787 with workspace local-default"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
