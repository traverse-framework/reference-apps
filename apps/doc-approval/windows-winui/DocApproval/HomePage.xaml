<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DocApproval.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="20" MaxWidth="960">
            <TextBlock Text="Analyze Document" Style="{ThemeResource SubtitleTextBlockStyle}" />

            <TextBox
                x:Name="DocumentBox"
                AcceptsReturn="True"
                TextWrapping="Wrap"
                PlaceholderText="Paste document text…"
                MinHeight="140" />

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="SubmitButton" Content="Analyze" Click="SubmitButton_Click" />
                <Button Content="Reset" Click="ResetButton_Click" />
            </StackPanel>

            <TextBlock
                x:Name="OfflineHint"
                Text="Runtime offline — start with `cargo run -p traverse-cli -- serve`"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Visibility="Collapsed" />

            <TextBlock Text="Analysis Result" Style="{ThemeResource SubtitleTextBlockStyle}" />

            <StackPanel x:Name="OutputPanel" Spacing="8">
                <TextBlock
                    x:Name="IdleText"
                    Text="Submit a document above to start analysis."
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="LoadingText" Text="Starting analysis…" Visibility="Collapsed" />
                <TextBlock x:Name="PollingText" FontFamily="Consolas" FontSize="12" Visibility="Collapsed" />
                <TextBlock x:Name="ErrorText" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap" />

                <Grid x:Name="OutputGrid" Visibility="Collapsed" ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Document type" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="DocTypeValue" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Parties" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="PartiesValue" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Amounts" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="AmountsValue" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Confidence" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="ConfidenceValue" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Recommendation" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock x:Name="RecommendationValue" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />
                </Grid>

                <Expander x:Name="TraceExpander" Header="Trace" Visibility="Collapsed">
                    <ItemsControl x:Name="TraceList" />
                </Expander>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
