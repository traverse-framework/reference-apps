<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DocApproval.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="480">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBox
                x:Name="WorkspaceBox"
                Header="Workspace"
                PlaceholderText="local-default"
                TextChanged="Setting_TextChanged" />

            <TextBox
                x:Name="BundlePathBox"
                Header="Bundle path (optional override)"
                PlaceholderText="Assets/bundles/doc-approval"
                TextChanged="Setting_TextChanged" />

            <TextBlock
                Text="Embedded mode uses the bundled runtime/runtime.wasm. Restart the app after changing the bundle path."
                FontSize="12"
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
