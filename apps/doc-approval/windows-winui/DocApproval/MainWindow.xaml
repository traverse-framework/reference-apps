<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DocApproval.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="doc-approval">

    <NavigationView
        x:Name="NavView"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="True"
        PaneDisplayMode="LeftCompact"
        SelectionChanged="NavView_SelectionChanged">

        <NavigationView.Header>
            <StackPanel Orientation="Horizontal" Spacing="8" Padding="12,8">
                <TextBlock
                    x:Name="ModeText"
                    Text="Embedded"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="Gray" />
                <TextBlock x:Name="StatusText" Text="Starting…" VerticalAlignment="Center" />
                <TextBlock
                    x:Name="WorkspaceText"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
                <TextBlock
                    x:Name="WorkflowText"
                    FontFamily="Consolas"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>
        </NavigationView.Header>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Window>
